# ─────────────────────────────────────────────────────────────────────────────
# WREI — Plik konfiguracyjny środowiska
# Skopiuj do .env i uzupełnij wartości
# ─────────────────────────────────────────────────────────────────────────────

# PostgreSQL
POSTGRES_DB=wrei
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Ollama — modele działają na HOŚCIE, nie w Dockerze
# host.docker.internal to specjalny adres: kontener → host (Windows/Mac)
OLLAMA_URL=http://host.docker.internal:11434/api/chat
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_VISION_MODEL=moondream

# Telegram (Faza 5 — alerty)
# Utwórz bota przez @BotFather, chat_id przez @userinfobot
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# Multi-miasto (comma-separated slugi)
# Obsługiwane: warszawa, krakow, wroclaw, poznan, gdansk, gdynia, katowice, lodz
TARGET_CITIES=warszawa

# Deweloperuch — historia przy starcie (w dniach)
# 1825 = 5 lat; 365 = 1 rok; 90 = 3 miesiące
RCN_INITIAL_LOAD_DAYS=1825
